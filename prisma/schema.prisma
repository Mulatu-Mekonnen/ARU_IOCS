generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ApprovalHistory {
  id         String   @id @default(cuid())
  agenda     Agenda   @relation(fields: [agendaId], references: [id])
  agendaId   String
  action     String
  comment    String?
  actionBy   User     @relation("UserActions", fields: [actionById], references: [id])
  actionById String
  createdAt  DateTime @default(now())
}

enum Role {
  ADMIN
  HEAD
  STAFF
  VIEWER
}

enum AgendaStatus {
  PENDING
  APPROVED
  REJECTED
  FORWARDED
  ARCHIVED
}

model Office {
  id        String   @id @default(uuid())
  name      String   @unique
  users     User[]
  sentAgendas     Agenda[] @relation("SentAgendas")
  receivedAgendas Agenda[] @relation("ReceivedAgendas")
  currentAgendas  Agenda[] @relation("CurrentAgendas")
  routesFrom     AgendaRoute[] @relation("FromOffice")
  routesTo       AgendaRoute[] @relation("ToOffice")
  createdAt DateTime @default(now())
}

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String
  role     Role    @default(STAFF)
  active   Boolean @default(true)

  officeId String?
  office   Office? @relation(fields: [officeId], references: [id])

  agendas         Agenda[] @relation("CreatedAgendas")
  approvedAgendas Agenda[] @relation("ApprovedAgendas")
  approvalActions ApprovalHistory[] @relation("UserActions")
  routedAgendas   AgendaRoute[] @relation("UserRoutedAgendas")

  createdAt DateTime @default(now())
}

model Agenda {
  id String @id @default(cuid())

  title       String
  description String?

  // Attachment metadata
  attachmentUrl  String?
  attachmentName String?
  attachmentSize Int?

  status      AgendaStatus @default(PENDING)

  createdById String
  createdBy   User   @relation("CreatedAgendas", fields: [createdById], references: [id])

  senderOfficeId   String?
  senderOffice     Office? @relation("SentAgendas", fields: [senderOfficeId], references: [id])

  receiverOfficeId String?
  receiverOffice   Office? @relation("ReceivedAgendas", fields: [receiverOfficeId], references: [id])

  currentOfficeId String?
  currentOffice   Office? @relation("CurrentAgendas", fields: [currentOfficeId], references: [id])

  approvedById String?
  approvedBy   User?   @relation("ApprovedAgendas", fields: [approvedById], references: [id])

  approvalHistories ApprovalHistory[]
  routes            AgendaRoute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgendaRoute {
  id          String   @id @default(cuid())
  agenda      Agenda   @relation(fields: [agendaId], references: [id])
  agendaId    String

  fromOffice  Office   @relation("FromOffice", fields: [fromOfficeId], references: [id])
  fromOfficeId String

  toOffice    Office   @relation("ToOffice", fields: [toOfficeId], references: [id])
  toOfficeId   String

  routedBy    User     @relation("UserRoutedAgendas", fields: [routedById], references: [id])
  routedById  String

  routedAt    DateTime @default(now())
}
